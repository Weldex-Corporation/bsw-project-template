# LP-MSPM0G3507 — Renode Machine Script
# Silicon model: bsw/platform/bsw-mcal-msp/renode/mspm0g3507.repl  (shared)
# Python peripheral models: bsw/platform/bsw-mcal-msp/renode/models/  (shared)
# Board-specific init (syscfg_lp.c) is in firmware, not in the .repl.

mach create "lp_mspm0g3507"
machine LoadPlatformDescription @bsw/platform/bsw-mcal-msp/renode/mspm0g3507.repl

# WWDT0/1 — absorbs service/feed writes, never resets in SIL
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_wwdt.py 0x40080000 0x1200 True "wwdt0"
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_wwdt.py 0x40082000 0x1200 True "wwdt1"

# TIMG8 — pre-defined GPT, IRQ 2, 1 MHz tick (CPS=32)
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_timg8.py 0x40090000 0x2000 True "timg8"

# TIMG7 — main GPT / scheduler tick, IRQ 20, 1 MHz tick (CPS=32)
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_timg7.py 0x4086A000 0x2000 True "timg7"

# DMA — on DMAEN copies bytes via sysbus then fires UART TX IRQ
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_dma.py 0x4042A000 0x1400 True "dma"

# UART1 / UART0 — TX capture + EOT_DONE IIDX
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_uart.py 0x40100000 0x2000 True "uart1"
machine PyDevFromFile @bsw/platform/bsw-mcal-msp/renode/models/mspm0_uart.py 0x40108000 0x2000 True "uart0"
