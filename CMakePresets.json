{
  "version": 3,
  "configurePresets": [
    {
      "name": "bsw-mcal-msp",
      "displayName": "Firmware — TI MSPM0G (LP-MSPM0G3507)",
      "toolchainFile": "${sourceDir}/cmake/arm-none-eabi.cmake",
      "binaryDir": "${sourceDir}/build/bsw-mcal-msp",
      "cacheVariables": {
        "PLATFORM":          "target",
        "BOARD":             "lp_mspm0g3507",
        "BSW_PLATFORM":      "bsw-mcal-msp",
        "PYOCD_TARGET":      "MSPM0G3507",
        "BUILD_TESTS":       "OFF",
        "CMAKE_BUILD_TYPE":  "Release"
      }
    },
    {
      "name": "host-test",
      "displayName": "Unit Test — Host (Windows MinGW / Linux GCC)",
      "toolchainFile": "${sourceDir}/cmake/toolchain-host.cmake",
      "binaryDir": "${sourceDir}/build/host-test",
      "cacheVariables": {
        "PLATFORM":         "posix",
        "BUILD_TESTS":      "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "renode-sil",
      "displayName": "SIL — Renode ARM Emulator",
      "toolchainFile": "${sourceDir}/cmake/arm-none-eabi.cmake",
      "binaryDir": "${sourceDir}/build/renode-sil",
      "cacheVariables": {
        "PLATFORM":         "renode",
        "BOARD":            "lp_mspm0g3507",
        "BSW_PLATFORM":     "bsw-mcal-msp",
        "BUILD_TESTS":      "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    { "name": "bsw-mcal-msp",  "configurePreset": "bsw-mcal-msp" },
    { "name": "host-test",     "configurePreset": "host-test" },
    { "name": "renode-sil",    "configurePreset": "renode-sil" }
  ],
  "testPresets": [
    {
      "name": "host-test",
      "configurePreset": "host-test",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error" }
    }
  ]
}
